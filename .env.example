# ─── App ──────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_SECRET_KEY=jwt-secret-change-me-in-production
VERSION=2.0.0

# ─── Database ─────────────────────────────────────────────
POSTGRES_USER=stockuser
POSTGRES_PASSWORD=stockpass
POSTGRES_DB=stockpro
DATABASE_URL=postgresql://stockuser:stockpass@localhost:5432/stockpro

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── External APIs ────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key        # free at https://newsapi.org
ALPHA_VANTAGE_KEY=your_av_key       # free at https://alphavantage.co
POLYGON_API_KEY=                     # optional — polygon.io

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ─── Monitoring ───────────────────────────────────────────
SENTRY_DSN=                          # optional — sentry.io
GRAFANA_PASSWORD=admin
PGADMIN_EMAIL=admin@stockpro.local
PGADMIN_PASSWORD=admin

# ─── ML ───────────────────────────────────────────────────
MODEL_REGISTRY_DIR=./ml_engine/registry
LSTM_SEQ_LEN=60
LSTM_FORECAST_DAYS=7
XGBOOST_N_ESTIMATORS=300

# ─── Feature flags ────────────────────────────────────────
FEATURE_OPTIONS_CHAIN=true
FEATURE_PORTFOLIO=true
FEATURE_ALERTS=true
FEATURE_TRANSFORMER_MODEL=false
